{
  "manifest_version": 3,
  "name": "LeanIX Accelerate",
  "version": "1.0.6",
  "description": "Unlock new levels of efficiency and productivity — the ultimate browser extension for LeanIX users.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.leanix.net/*",
    "https://*.leanix.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.leanix.net/*",
        "https://*.leanix.com/*"
      ],
      "js": [
        "src/shared/storage.js",
        "src/shared/dom-utils.js",
        "src/shared/modal.js",
        "src/shared/xlsx.full.min.js",
        "src/content/features/data-export.js",
        "src/content/features/print-export.js",
        "src/content/features/documents-export.js",
        "src/content/features/update-notification.js",
        "src/content/index.js"
      ],
      "css": ["src/content/leanix.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "LeanIX Custom Features",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  }
}
